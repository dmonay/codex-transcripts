<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.codex-transcriptsd</string>

    <key>ProgramArguments</key>
    <array>
      <!-- Update this path to wherever you build/install the binary -->
      <string>/Users/YOUR_USER/path/to/codex-transcriptsd</string>
      <string>--listen</string>
      <string>127.0.0.1:7878</string>
      <!-- If needed, point at the generator explicitly (e.g. ~/.local/bin/codex-transcripts) -->
      <!-- <string>--generator-cmd</string> -->
      <!-- <string>/Users/YOUR_USER/.local/bin/codex-transcripts</string> -->
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/codex-transcriptsd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/codex-transcriptsd.err.log</string>
  </dict>
</plist>

